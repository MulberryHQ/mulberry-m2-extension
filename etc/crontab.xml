<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="mulberry">
        <job name="test_warranty_sendorder" instance="Test\Warranty\Cron\SendOrder" method="execute">
            <schedule>* * * * *</schedule>
        </job>
        <job name="test_warranty_sendcart" instance="Test\Warranty\Cron\SendCart" method="execute">
            <schedule>* * * * *</schedule>
        </job>
    </group>
</config>
